    "@fastify/jwt": "^9.1.0",
    "@fastify/sensible": "^6.0.3",
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1",
    "slugify": "^1.6.6",
    "zod": "^3.25.49"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "prisma": "^6.9.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
