{
  "name": "inkflow-comics",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test",
    "test:e2e": "playwright test",
    "test:security": "pnpm audit --audit-level moderate",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "db:migrate": "pnpm --filter server db:migrate",
    "db:seed": "pnpm --filter server db:seed"
  },
  "pnpm": {
    "overrides": {
      "tsx>esbuild": "0.28.1"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
